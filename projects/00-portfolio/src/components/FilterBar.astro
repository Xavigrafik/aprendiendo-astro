---
import Badge from "./../components/Badge.astro";
const { items } = Astro.props;
---

<nav>
    <ul>
        {items && <span>Filters:</span>}
        {
            items.map((tag: string) => (
                <li class="filter-item">
                    <button class="filter-btn" data-filter={tag}>
                        <Badge variant={tag}>{tag}</Badge>
                    </button>
                </li>
            ))
        }
        <li>
            <button class="filter-btn active" data-filter="all">
                <Badge variant="all">All</Badge>
            </button>
        </li>
    </ul>
</nav>
<style lang="scss">
    nav {
        ul {
            display: flex;
            list-style: none;
            padding: 0;
            gap: 0.5rem;

            li {
                button {
                    border: 0px solid transparent;
                    background-color: transparent;
                    padding: 0;
                }

                &.active {
                    span.badge {
                        border: 3px solid black;
                        box-shadow: 2px 2px 2px 0px rgba(0,0,0,0.5);
                    }
                }
            }
        }
    }
    .filter-btn { 
        background: none; cursor: pointer; padding: 0; 
        transition: opacity 0.2s;
    }
    .filter-btn:not(.active) { opacity: 0.5; border: none; }
    .filter-btn.active { 
        opacity: 1; transform: scale(1.05); 
        & :global(.badge) {
            border: 2px solid black !important;
        }
    }
</style>
<script>
    const buttons = document.querySelectorAll('.filter-btn');
    const projects = document.querySelectorAll('.project-card');

    buttons.forEach(button => {
        button.addEventListener('click', () => {
            // Usamos "" como fallback si getAttribute devuelve null
            const filter = button.getAttribute('data-filter') || "";

            buttons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');

            projects.forEach(project => {
                const projectElement = project as HTMLElement;
                const tagsRaw = projectElement.dataset.tags || "";
                const tagsArray = tagsRaw.split(' '); 

                if (filter === 'all' || tagsArray.includes(filter)) {
                    projectElement.style.display = 'block';
                } else {
                    projectElement.style.display = 'none';
                }
            });
        });
    });
</script>