---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Button from "../../components/Button.astro";
import Icon from "../../components/Icon.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
    const ceramics = await getCollection("ceramics");
    return ceramics.map((item: CollectionEntry<"ceramics">) => ({
        params: { id: item.id },
        props: { item },
    }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { title, author, description, img, gallery } = item.data;

// Optimizamos la descripción para el meta tag (máx 160 caracteres)
const seoDescription =
    description.length > 155
        ? description.substring(0, 155) + "..."
        : description;
---

<MainLayout title={title}>
    <div class="ceramic-detail-block">
        <Image
            class="main-img"
            src={img}
            alt={title}
            width={800}
            height={600}
        />
        <h1>{title}</h1>
        <h5>por {author}</h5>

        <div class="content">
            <p>{seoDescription}</p>
        </div>

        <Content />

        <!-- Galería de Imágenes -->
        {
            gallery && gallery.length > 0 && (
                <section class="gallery">
                    {gallery.map((photo, index) => (
                        <div class="gallery-item">
                            <Image
                                src={photo}
                                alt={`Detalle ${index + 1} de ${title}`}
                                width={600}
                            />
                        </div>
                    ))}
                </section>
            )
        }
    </div>
    <Button href="/ceramics"> <Icon name="arrow-left" size={24} /> Volver a la lista </Button>
</MainLayout>

<style>
    .ceramic-detail-block {
        padding: 1rem 0;
    }
    .main-img {
        width: 100%;
        max-height: 400px;
        height: auto;
        border-radius: 12px;
        object-fit: cover;
    }
    .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
    }
    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 8px;
    }
    .author {
        font-style: italic;
        color: #666;
    }
    .buy-link {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.5rem 1rem;
        background-color: #333;
        color: white;
        text-decoration: none;
        border-radius: 4px;
    }
</style>
