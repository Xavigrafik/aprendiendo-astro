---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import CeramicLayout from "../../layouts/CeramicLayout.astro";

const ceramics = await getCollection("ceramics");
---

<CeramicLayout title="CeramicLayout">
    <h1>CeramicLayout</h1>

    <div class="ceramic-grid">
        {
            ceramics.map((item) => (
                <article>
                    <Image
                        src={item.data.img}
                        alt={item.data.title}
                        width={400}
                    />
                    <div class="overlay">
                        <h2>{item.data.title}</h2>
                        <a href={`/ceramics/${item.id}`}>Ver detalles</a>
                    </div>
                </article>
            ))
        }
    </div>
</CeramicLayout>

<style>
    .ceramic-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
        padding: 1rem 0;

        article {
            position: relative; /* Importante para que el overlay se base en este contenedor */
            overflow: hidden;
            border-radius: 12px;
            aspect-ratio: 1 / 1; /* Opcional: hace las tarjetas cuadradas para un look más artístico */
            background-color: #000;

            /* Estilo para la imagen para que ocupe todo el fondo */
            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
                display: block;
            }

            .overlay {
                position: absolute;
                inset: 0; /* Ocupa todo el espacio (top, left, right, bottom: 0) */
                background-color: rgba(0, 0, 0, 0); /* Invisible al principio */
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                text-align: center;
                padding: 1rem;
                transition: background-color 0.3s ease;
                
                /* Ocultamos el contenido inicialmente */
                h2, a {
                    opacity: 0;
                    transform: translateY(10px);
                    transition: all 0.3s ease;
                }

                h2 {
                    color: white;
                    margin: 0 0 1rem 0;
                    font-size: 1.5rem;
                }
            }

            /* --- HOVER --- */
            &:hover {
                img {
                    transform: scale(1.1); /* Efecto de zoom en la imagen */
                }

                .overlay {
                    background-color: rgba(0, 0, 0, 0.7); /* Oscurece el fondo */
                    
                    h2, a {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
            }

            /* Ajuste del botón para que se vea bien sobre oscuro */
            a {
                text-decoration: none;
                color: #fff;
                font-weight: 600;
                font-size: 0.9rem;
                padding: 0.5rem 1rem;
                border: 1px solid #fff;
                border-radius: 6px;

                &:hover {
                    background: white;
                    color: black;
                }
            }
        }
    }

    h1 {
        margin-bottom: 2rem;
        font-size: 2.5rem;
    }
</style>