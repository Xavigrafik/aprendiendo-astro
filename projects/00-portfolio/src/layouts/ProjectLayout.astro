---
import MainLayout from './MainLayout.astro';

const { title } = Astro.props;
---

<MainLayout title={title}>
  <div class="project-container">
    <aside>
      <p>Categoría: Desarrollo Web</p>
    </aside>
    
    <main>
      <slot />
    </main>
  </div>
</MainLayout>

<style>
  .project-container {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 2rem;
  }
</style>